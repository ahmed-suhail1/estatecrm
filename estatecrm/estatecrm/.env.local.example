# Create a free project at https://supabase.com, then run the SQL files in
# supabase/migrations/ (in order) via the SQL Editor, then fill these in
# from Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only needed if you enable the office-wide access PIN gate
# (see components/agent/AccessGate.tsx)
NEXT_PUBLIC_OFFICE_ACCESS_PIN=
